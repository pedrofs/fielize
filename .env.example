# Supabase — public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only (auto-provisioned by `vercel integration add supabase`)
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Platform
NEXT_PUBLIC_PLATFORM_NAME=Fielize
NEXT_PUBLIC_ROOT_DOMAIN=fielize.com

# Magic link signing (32+ chars, server-only). Generate: `openssl rand -hex 32`
JWT_SECRET=

# Z-API (WhatsApp Business). Optional in early phases.
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_WEBHOOK_SECRET=

# PostHog (optional in early phases)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_KEY=

# Skip env validation at build time (CI / preflight). Default: false.
# SKIP_ENV_VALIDATION=true
