# Copy this file to .env and fill in the values. Loaded automatically by overmind/foreman when running `bin/dev`.
# Note: .env is gitignored.

# Clerk publishable key — exposed to the browser by Vite.
# From Clerk Dashboard → API keys → choose "React".
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk secret key is read from Rails encrypted credentials, not env.
# Set it with: bin/rails credentials:edit
# Expected shape:
#   clerk:
#     secret_key: sk_test_...
